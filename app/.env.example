# Supabase project used for cloud sync of tournaments.
# Copy this file to .env and fill in your project's values
# (Project Settings > API in the Supabase dashboard).
# If these are left unset, the app runs in local-only mode
# (data stays in the browser's localStorage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
